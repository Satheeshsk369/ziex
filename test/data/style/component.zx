pub fn Page(allocator: zx.Allocator) zx.Component {
    const style: zx.StyleSheet = .{
        .color = .hex(0x0000ff),
    };
    return (
        <StyledCard @allocator={allocator} style={style}>
             Hello Component 
        </StyledCard>
    );
}

const StyledCardProps = struct { style: zx.StyleSheet, children: zx.Component };
fn StyledCard(allocator: zx.Allocator, props: StyledCardProps) zx.Component {
    return (
        <div @allocator={allocator} class="card" style={props.style}>
            {props.children}
        </div>
    );
}

const zx = @import("zx");
